# Roboflow private API key. Keep this file on the server only.
ROBOFLOW_API_KEY=your_private_api_key

# Publishable key from https://app.roboflow.com/settings/api
# Browser inference downloads model files from Roboflow in the browser.
# Set false when your network cannot reach Roboflow without VPN.
ROBOFLOW_BROWSER_INFERENCE=false
ROBOFLOW_PUBLISHABLE_KEY=rf_your_publishable_key

# Your trained model identifier in project/version format.
# Example: taylor-swift-records/3
ROBOFLOW_MODEL_ID=your-project/1
DASHBOARD_MODELS=lego=lego-ai/3,people=people-mvoqs/4

# No-VPN runtime mode: point the dashboard at a local Roboflow Inference Server.
# Use https://serverless.roboflow.com only when Roboflow-hosted endpoints are reachable.
ROBOFLOW_API_URL=http://127.0.0.1:9001

# Stop a Roboflow request if it takes longer than this.
ROBOFLOW_TIMEOUT_MS=20000

PORT=3000
